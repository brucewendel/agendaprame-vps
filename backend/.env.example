HOST=131.100.24.44
PORT=60561
SERVICE_NAME=wint
DB_USER=jacomercial
DB_PASSWORD=


SECRET_KEY=chave-secreta-padrao
JWT_EXP_HOURS=24

# Login protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=600
LOGIN_BLOCK_SECONDS=900

# CORS
# Inclua aqui a origem real quando acessar direto pela porta 8001
# ou o dominio publico configurado no Nginx Manager.
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Password migration (legacy -> bcrypt)
ALLOW_LEGACY_PASSWORD=1
PASSWORD_MIGRATE_ON_LOGIN=1
PASSWORD_HASH_ROUNDS=12
PASSWORD_HASH_COLUMN=SENHA_HASH
